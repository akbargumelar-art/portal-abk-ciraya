{
  "name": "portal-abk-ciraya-backend",
  "version": "1.0.0",
  "description": "Backend API for Portal ABK Ciraya",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
